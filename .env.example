SPRING_PROFILES_ACTIVE=prod
PORT=8383

# Option 1: variables generiques
DATABASE_URL=jdbc:postgresql://HOST:5432/DB_NAME
DATABASE_USERNAME=DB_USERNAME
DATABASE_PASSWORD=DB_PASSWORD

# Option 2: variables Railway PostgreSQL
# PGHOST=HOST
# PGPORT=5432
# PGDATABASE=DB_NAME
# PGUSER=DB_USERNAME
# PGPASSWORD=DB_PASSWORD

JWT_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
JWT_EXPIRATION_SECONDS=600

BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=

DDL_AUTO=update
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
